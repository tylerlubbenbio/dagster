# =============================================================================
# STANDARD GITIGNORE FOR ALL PROJECTS
# =============================================================================

# -----------------------------------------------------------------------------
# Local Runtime Folders
# -----------------------------------------------------------------------------
# _ARCHIVED, _TESTING, _LOGS, _LOCAL_FILES are tracked in this repo
# connections/ credentials are in .env now — never commit raw connection files
connections/
*._ARCHIVED
.tmp_dagster_home*/
# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# Environment Variables (NEVER COMMIT)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
**/envs/*.env

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Data Files (DO NOT COMMIT)
# -----------------------------------------------------------------------------
*.csv
*.jsonl


# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Build / Dist
# -----------------------------------------------------------------------------
dist/
build/
*.local

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
node_modules/
.pnp/
.pnp.js

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*.cache
temp/
tmp/

# -----------------------------------------------------------------------------
# Database Files (local)
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# Archives
# -----------------------------------------------------------------------------
*.tar.gz
*.zip
*.rar
*.7z
